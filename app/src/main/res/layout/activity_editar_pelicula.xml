<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".EditarPeliculaActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/lblEditarEncabezado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modificar Película"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/imgPeli"
            android:layout_width="140dp"
            android:layout_height="180dp"
            android:layout_marginTop="24dp"
            android:background="#E0E0E0"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintTop_toBottomOf="@id/lblEditarEncabezado"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvCambiarImagen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Toca para cambiar imagen"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgPeli" />

        <EditText
            android:id="@+id/editTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Título de la película"
            android:inputType="textCapSentences"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvCambiarImagen"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/editGenero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Género (Ej: Terror, Comedia...)"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/editTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/lblRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu valoración:"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/editGenero"
            app:layout_constraintStart_toStartOf="parent" />

        <RatingBar
            android:id="@+id/ratingEditar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="1.0"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/lblRating"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblOpinion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opinión / Crítica:"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/ratingEditar"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/editOpinion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Escribe aquí qué te ha parecido..."
            android:gravity="top"
            android:inputType="textMultiLine"
            android:lines="5"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/lblOpinion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnGuardarCambios"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="GUARDAR CAMBIOS"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/editOpinion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnCancelar"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:textColor="@color/black"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnGuardarCambios"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>