<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgDetalle"
            android:layout_width="150dp"
            android:layout_height="200dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtDetalleTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextoDAS.Titulo"
            android:text="Título de la Peli"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgDetalle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtDetalleGenero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextoDAS.Titulo"
            android:text="@string/g_nero_drama"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetalleTitulo"
            app:layout_constraintStart_toStartOf="parent" />

        <RatingBar
            android:id="@+id/ratingDetalle"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetalleGenero"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtDetallePendiente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFE082"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="@string/pendiente"
            android:textColor="#E65100"
            style="@style/TextoDAS.Titulo"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ratingDetalle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblOpinion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mi_opini_n"
            style="@style/TextoDAS.Titulo"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetallePendiente"
            app:layout_constraintStart_toStartOf="parent" />


        <TextView
            android:id="@+id/txtDetalleOpinion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/opinionTexto"
            android:layout_marginTop="8dp"
            style="@style/TextoDAS"
            app:layout_constraintTop_toBottomOf="@id/lblOpinion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/editar_pel_cula"
            style="@style/BotonDAS"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetalleOpinion"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnCompartir"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/compartir_opini_n"
            android:textColor="@color/colorSecondary"
            app:layout_constraintTop_toBottomOf="@id/btnEditar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>