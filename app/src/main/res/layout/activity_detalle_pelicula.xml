<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgDetalle"
            android:layout_width="150dp"
            android:layout_height="200dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtDetalleTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título de la Peli"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgDetalle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtDetalleGenero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Género: Drama"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetalleTitulo"
            app:layout_constraintStart_toStartOf="parent" />

        <RatingBar
            android:id="@+id/ratingDetalle"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetalleGenero"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblOpinion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi Opinión:"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/ratingDetalle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtDetalleOpinion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Aquí va la opinión completa que escribió el usuario al registrar la película."
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/lblOpinion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar Película"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/txtDetalleOpinion"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnCompartir"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compartir opinión"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/btnEditar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>